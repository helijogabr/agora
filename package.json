{
  "name": "agora",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "dev": "turbo run _dev studio:dev",
    "build": "turbo run _build",
    "sync": "turbo run _sync",
    "lint": "turbo run _lint",
    "test": "turbo run _test",
    "check": "turbo run _check",
    "typecheck": "turbo run _typecheck",
    "db:check": "turbo run _db:check",
    "studio:dev": "drizzle-kit studio --config drizzle.config.dev.ts",
    "studio:prod": "drizzle-kit studio --config drizzle.config.ts",
    "_dev": "astro dev",
    "_build": "astro build",
    "_sync": "astro sync",
    "_check": "astro check",
    "_typecheck": "tsc --noEmit",
    "_lint": "biome check",
    "_db:check": "drizzle-kit check --config drizzle.config.ts",
    "_test": "vitest --passWithNoTests --run",
    "astro": "astro",
    "push:dev": "drizzle-kit push --force --config drizzle.config.dev.ts",
    "push:prod": "drizzle-kit push --config drizzle.config.ts"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10.33.0"
    }
  },
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.2",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@formkit/auto-animate": "^0.9.0",
    "@iconify-json/mdi": "^1.2.3",
    "@libsql/client": "^0.17.4",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.1",
    "@vercel/functions": "^3.7.5",
    "astro": "^7.0.7",
    "astro-icon": "^1.1.5",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "leaflet": "^1.9.4",
    "lodash": "^4.18.1",
    "nanostores": "^1.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-select": "^5.10.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.4.10",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/ioredis-mock": "^8.2.7",
    "@types/leaflet": "^1.9.21",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "ioredis-mock": "^8.13.1",
    "jsdom": "^29.1.1",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "turbo": "^2.10.4",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "vite": "^7"
  }
}
