{
  "extends": "astro/tsconfigs/strictest",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "verbatimModuleSyntax": true,
    "paths": {
      "@/*": ["./src/*"],
      "@components": ["./src/components/*"],
      "@layouts": ["./src/layouts/*"],
      "@styles": ["./src/styles/*"],
      "@assets": ["./src/assets/*"],
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
