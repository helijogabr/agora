---
const { invalidateCache, user } = Astro.locals;
Astro.locals.d1Session = null;
---

{
  invalidateCache && user && (
    <script is:inline define:vars={{ user, hash: invalidateCache }}>
      window.__USER__ = user;

      requestIdleCallback(() => {
        localStorage.setItem('user_cache', JSON.stringify(user));
        document.cookie = `hasCache=${hash}; path=/; max-age=31536000; SameSite=Lax`;
      })
    </script>
  )
}
