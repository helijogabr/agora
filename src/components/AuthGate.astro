---
import { session } from "@/userStore";

const hasCache = Astro.cookies.get("hasCache")?.value;
const user = Astro.locals.user?.info;

const invalidate = user && (!hasCache || hasCache !== user.name);
console.log("AuthGate", { user, hasCache, invalidate });
console.log("Store", session?.getStore());

if (invalidate && user) {
  Astro.cookies.set("hasCache", user.name, {
    expires: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000),
    path: "/",
    httpOnly: false,
    sameSite: "lax",
  });
}
---

{
  invalidate && (
    <script is:inline define:vars={{ user }}>
      window.__USER__ = user; localStorage.setItem('user_cache',
      JSON.stringify(user));
    </script>
  )
}
