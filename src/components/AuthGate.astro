---
const { invalidateCache, user } = Astro.locals;
---

{
  invalidateCache && user?.info && (
    <script is:inline define:vars={{ user: user.info }}>
      window.__USER__ = user;

      requestIdleCallback(() => {
        localStorage.setItem('user_cache',
        JSON.stringify(user)); const u = encodeURIComponent(user.name);
        document.cookie = `hasCache=${u}; path=/; max-age=31536000; SameSite=Lax`;
      })
    </script>
  )
}
