---
import Layout from "@layouts/Layout.astro";
import LogoutButton from "@components/LogoutButton.astro";

const user = Astro.locals.user.info;
---

<Layout title="Meu Perfil" showNav={true}>
  <main class="flex flex-1 flex-col items-center justify-center">
    <h1 class="text-2xl font-bold">Meu Perfil</h1>
    <p class="mt-4">Bem-vindo(a), {user.name}!</p>
    <p class="mt-2">Cidade: {user.city}</p>

    {
      user.role && (
        <p class="mt-2">
          Cargo: <strong>{user.role}</strong>
        </p>
      )
    }
    
    <LogoutButton />
        
  </main>
</Layout>



