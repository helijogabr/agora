---
import { actions } from "astro:actions";
import CustomInputPassword from "@components/CustomInputPassword";
import CustomInputText from "@components/CustomInputText";
import Layout from "../layouts/Layout.astro";

const redirect = Astro.url.searchParams.get("return") ?? undefined;
const returnTo = redirect ? `?return=${encodeURIComponent(redirect)}` : "";

const result = Astro.getActionResult(actions.createUserForm);

if (result && !result.error) {
  return Astro.redirect(result.data.redirect || "/");
}
---

<Layout title="Cadastro" showNav={false}>
  <main
    class="flex flex-1 flex-col items-center justify-center bg-[#50be91] dark:bg-[#1e4937]"
  >
    <form
      method="POST"
      action={actions.createUserForm}
      class="flex h-1/2 w-9/10 flex-col items-center justify-center gap-4 rounded-3xl bg-[#d3d3d3] shadow-2xl md:w-1/2 dark:bg-gray-900"
    >
      <input type="hidden" name="redirect" value={redirect} />

      <CustomInputText title="Usuário" name="username" />
      <CustomInputPassword title="Senha" name="password" />
      <CustomInputText title="Cidade" name="city" />
      <div class="flex h-8 w-8/10 items-center justify-center font-bold">
        {
          result && result.error && (
            <p style={{ color: "red" }}>{result.error.message}</p>
          )
        }
      </div>
      <button
        type="submit"
        class="h-15 w-40 cursor-pointer rounded-4xl bg-[#50be91] font-bold text-white hover:bg-[#50be90d3] hover:text-[#1e4937cb] dark:bg-[#327c5d]"
        >Cadastrar
      </button>
      <div class="flex flex-row gap-1">
        <h1>Já possui uma conta?</h1>
        <a href=`/login${returnTo}` class="font-bold text-[#3d9470]">Entrar</a>
      </div>
    </form>
  </main>
</Layout>
