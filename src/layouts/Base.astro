---
import { ClientRouter } from "astro:transitions";
import AuthGate from "@components/AuthGate.astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;

const preferredTheme = Astro.cookies.get("theme")?.value as
  | "light"
  | "dark"
  | undefined;
---

<!doctype html>
<html
  lang="en"
  class="h-full bg-gray-200 dark:bg-gray-900"
  {...preferredTheme ? { "data-theme": preferredTheme } : {}}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <AuthGate />
    <title>{title}</title>
    <slot name="head" />
    {
      !preferredTheme && (
        <script is:inline>
          const local = localStorage.getItem("theme");
          const savedTheme = local ?? (window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light");

          const root = document.documentElement;
          root.dataset.theme = savedTheme;

          localStorage.setItem("theme", savedTheme);
          cookieStore.set({
            name: "theme",
            value: savedTheme,
            expires: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000),
            path: "/",
          });
        </script>
      )
    }
  </head>
  <body class="flex h-full flex-col dark:text-gray-300">
    <slot />
  </body>
</html>
